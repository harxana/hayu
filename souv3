-- TAB SWITCHING
-- ===================================================
local TABS={
    souvenir  ={panel=PanelSouvenir,   btn=TabSouvenir,   color=Color3.fromRGB(200,120,0)},
    claim     ={panel=PanelClaim,      btn=TabClaim,      color=Color3.fromRGB(40,110,200)},
    hatch     ={panel=PanelHatch,      btn=TabHatch,      color=Color3.fromRGB(120,60,200)},
    delete    ={panel=PanelDelete,     btn=TabDelete,     color=Color3.fromRGB(180,40,40)},
    pushtrophy={panel=PanelPushTrophy, btn=TabPushTrophy, color=Color3.fromRGB(160,120,0)},
}
local function switchTab(name)
    activeTab=name
    for k,t in pairs(TABS) do
        t.panel.Visible=(k==name)
        if k==name then
            t.btn.BackgroundColor3=t.color; t.btn.TextColor3=Color3.fromRGB(255,255,255)
        else
            t.btn.BackgroundColor3=Color3.fromRGB(24,22,36); t.btn.TextColor3=Color3.fromRGB(130,130,165)
        end
    end
    ContentScroll.CanvasPosition=Vector2.new(0,0)
end
TabSouvenir.MouseButton1Click:Connect(function() switchTab("souvenir") end)
TabClaim.MouseButton1Click:Connect(function() switchTab("claim") end)
TabHatch.MouseButton1Click:Connect(function() switchTab("hatch") end)
TabDelete.MouseButton1Click:Connect(function() switchTab("delete") end)
TabPushTrophy.MouseButton1Click:Connect(function() switchTab("pushtrophy") end)
