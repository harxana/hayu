    _clGrad.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(220,70,70)),ColorSequenceKeypoint.new(1,Color3.fromRGB(160,40,40))})
end
local function setClaimOFF()
    ClaimStatusLbl.Text="Status: MATI"; ClaimStatusLbl.TextColor3=Color3.fromRGB(255,80,80)
    ClaimToggleBtn.Text="▶ NYALAKAN"; ClaimRunLbl.Text="Menunggu..."
    _clGrad.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(60,200,110)),ColorSequenceKeypoint.new(1,Color3.fromRGB(30,140,70))})
    for n=1,12 do if claimStatus[n] and claimStatus[n].Parent then claimStatus[n].Text="-"; claimStatus[n].TextColor3=Color3.fromRGB(140,140,170) end end
end
local function runClaimLoop()
    while claimAktif do
        for n=1,12 do
            if not claimAktif then break end
            if not claimActive[n] then if claimStatus[n] and claimStatus[n].Parent then claimStatus[n].Text="skip" end continue end
            ClaimRunLbl.Text="Claim: #"..n
            if claimStatus[n] and claimStatus[n].Parent then claimStatus[n].Text="⏳"; claimStatus[n].TextColor3=Color3.fromRGB(255,220,60) end
            fireOnlineAward(n)
            task.wait(0.4)
            if claimStatus[n] and claimStatus[n].Parent then claimStatus[n].Text="✔"; claimStatus[n].TextColor3=Color3.fromRGB(80,220,120) end
            task.wait(0.3)
        end
        for t=claimDelay,1,-1 do
            if not claimAktif then break end
            ClaimRunLbl.Text="Ulang dalam: "..t.." dtk"
            task.wait(1)
        end
    end
    setClaimOFF()
end
ClaimToggleBtn.MouseButton1Click:Connect(function()
    claimAktif=not claimAktif
    if claimAktif then setClaimON(); task.spawn(runClaimLoop) end
end)

