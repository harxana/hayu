-- Logika Push Trophy
local lastEquipped = ""

local function setPTON()
    PTStatusLbl.Text="Status: AKTIF ✅"; PTStatusLbl.TextColor3=Color3.fromRGB(80,255,120)
    PTToggleBtn.Text="⏹ MATIKAN"
    _ptGrad.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(220,70,70)),ColorSequenceKeypoint.new(1,Color3.fromRGB(160,40,40))})
end
local function setPTOFF()
    PTStatusLbl.Text="Status: MATI"; PTStatusLbl.TextColor3=Color3.fromRGB(255,80,80)
    PTToggleBtn.Text="▶ NYALAKAN"; PTRunLbl.Text="Menunggu..."
    PTActiveSvVal.Text="Menunggu..."; PTActiveSvVal.TextColor3=Color3.fromRGB(200,200,220)
    _ptGrad.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(60,200,110)),ColorSequenceKeypoint.new(1,Color3.fromRGB(30,140,70))})
    lastEquipped=""
end
local function runPushTrophyLoop()
    local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hrp = character:WaitForChild("HumanoidRootPart")
    while pushTrophyAktif do
        local posY = hrp.Position.Y
        PTHeightVal.Text = string.format("%.1f", posY)
        if posY > 14000 then
            PTZoneVal.Text="🏆 ZONE WINS"; PTZoneVal.TextColor3=Color3.fromRGB(80,220,120)
            PTRunLbl.Text="Y="..string.format("%.0f",posY).." | Wins aktif"
            if lastEquipped~="wins" then
                fireSouvenirWins(); lastEquipped="wins"
                PTActiveSvVal.Text="🏆 Souvenir Wins"; PTActiveSvVal.TextColor3=Color3.fromRGB(80,220,120)
                PTLogLbl.Text="Log: Equip Wins @ Y="..string.format("%.0f",posY)
            end
        elseif posY < 100 then
            PTZoneVal.Text="⚡ ZONE SPEED"; PTZoneVal.TextColor3=Color3.fromRGB(80,180,255)
            PTRunLbl.Text="Y="..string.format("%.0f",posY).." | Speed aktif"
            if lastEquipped~="speed" then
                fireSouvenirSpeed(); lastEquipped="speed"
                PTActiveSvVal.Text="⚡ Souvenir Speed"; PTActiveSvVal.TextColor3=Color3.fromRGB(80,180,255)
                PTLogLbl.Text="Log: Equip Speed @ Y="..string.format("%.0f",posY)
            end
        else
            PTZoneVal.Text="— Netral"; PTZoneVal.TextColor3=Color3.fromRGB(180,180,200)
            PTRunLbl.Text="Y="..string.format("%.0f",posY).." | Zona netral"
            lastEquipped=""
            PTActiveSvVal.Text="— (zona netral)"; PTActiveSvVal.TextColor3=Color3.fromRGB(160,160,180)
        end
        task.wait(0.3)
    end
    setPTOFF()
end
PTToggleBtn.MouseButton1Click:Connect(function()
    pushTrophyAktif=not pushTrophyAktif
    if pushTrophyAktif then setPTON(); task.spawn(runPushTrophyLoop) end
end)

