        RunLbl.Text = "● Aktif"; RunLbl.TextColor3 = Color3.fromRGB(80,255,120)
        svLoops[idx] = task.spawn(function()
            while sv.aktif do
                fireSouvenir(sv.slot)
                task.wait(0.5)
            end
        end)
    end

    TogBtn.MouseButton1Click:Connect(function()
        if sv.aktif then stopSvLoop() else startSvLoop() end
    end)
end

