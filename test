-- ══════════════════════════════════════════════
local function applyMode(mode, h)
    if mode == STATE.currentMode then return end
    STATE.currentMode = mode

    if mode == "WINS" then
        fireSouvenirWins()
        STATE.pushCount += 1
        PushCountLbl.Text   = tostring(STATE.pushCount)
        HeightZoneLbl.Text  = "🏆 WINS ZONE"
        HeightZoneLbl.TextColor3 = Color3.fromRGB(255, 215, 0)
        ModeIconLbl.Text    = "🏆"
        RunLbl.Text         = "WINS aktif — " .. math.floor(h) .. " studs"
        RunLbl.TextColor3   = Color3.fromRGB(255, 215, 0)
        hBarFill.BackgroundColor3 = Color3.fromRGB(255, 215, 0)
        fStroke.Color       = Color3.fromRGB(255, 215, 0)
        scSt.Color          = Color3.fromRGB(255, 215, 0)
        hcBarAccent.BackgroundColor3 = Color3.fromRGB(255, 215, 0)
        WinsStroke.Transparency  = 0.1
        SpeedStroke.Transparency = 0.8
        addLog("WINS aktif pada " .. math.floor(h) .. " studs", Color3.fromRGB(255, 215, 0))
        showToast("🏆 Souvenir WINS Aktif! Ketinggian: "..math.floor(h).." studs", "🏆", Color3.fromRGB(255, 215, 0))
        launchFirework(); task.delay(0.3, launchFirework); task.delay(0.6, launchFirework)

    elseif mode == "SPEED" then
        fireSouvenirSpeed()
        STATE.pushCount += 1
        PushCountLbl.Text   = tostring(STATE.pushCount)
        HeightZoneLbl.Text  = "⚡ SPEED ZONE"
        HeightZoneLbl.TextColor3 = Color3.fromRGB(80, 180, 255)
        ModeIconLbl.Text    = "⚡"
        RunLbl.Text         = "SPEED aktif — " .. math.floor(h) .. " studs"
        RunLbl.TextColor3   = Color3.fromRGB(80, 200, 255)
        hBarFill.BackgroundColor3 = Color3.fromRGB(80, 180, 255)
        fStroke.Color       = Color3.fromRGB(80, 180, 255)
        scSt.Color          = Color3.fromRGB(80, 180, 255)
        hcBarAccent.BackgroundColor3 = Color3.fromRGB(80, 180, 255)
        SpeedStroke.Transparency = 0.1
        WinsStroke.Transparency  = 0.8
        addLog("SPEED aktif pada " .. math.floor(h) .. " studs", Color3.fromRGB(80, 200, 255))
        showToast("⚡ Souvenir SPEED Aktif! Ketinggian: "..math.floor(h).." studs", "⚡", Color3.fromRGB(80, 180, 255))
        launchFirework(); task.delay(0.25, launchFirework)

    else -- IDLE / NORMAL
        HeightZoneLbl.Text  = "〰 NORMAL"
        HeightZoneLbl.TextColor3 = Color3.fromRGB(130, 125, 170)
        ModeIconLbl.Text    = "〰"
        RunLbl.Text         = "Memantau ketinggian..."
        RunLbl.TextColor3   = Color3.fromRGB(100, 96, 136)
        fStroke.Color       = Color3.fromRGB(255, 215, 0)
        scSt.Color          = Color3.fromRGB(255, 215, 0)
        hcBarAccent.BackgroundColor3 = Color3.fromRGB(255, 215, 0)
        WinsStroke.Transparency  = 0.6
        SpeedStroke.Transparency = 0.6
        addLog("Normal zone — " .. math.floor(h) .. " studs", Color3.fromRGB(130, 125, 170))
    end
end

-- ══════════════════════════════════════════════
-- MAIN LOOP
-- ══════════════════════════════════════════════
local function startLoop()
    STATE.running = true
    STATE.currentMode = "IDLE"
    StatusLbl.Text      = "● AKTIF"
    StatusLbl.TextColor3 = Color3.fromRGB(80, 255, 130)
    TogBtn.Text         = "■ MATIKAN"
    togGrad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(220, 65, 65)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(160, 35, 35)),
    })
    startParticles()
    showToast("🚀 Push Trophy aktif! Deteksi ketinggian ON", "🚀", Color3.fromRGB(80, 255, 130))
    addLog("Loop dimulai!", Color3.fromRGB(80, 255, 130))

    STATE.loop = task.spawn(function()
        while STATE.running do
            local h = getHeight()
            STATE.lastHeight = h

            -- update height display
            HeightValLbl.Text = math.floor(h) .. " studs"

            -- bar fill (0–20000 range clamp)
            local pct = math.clamp(h / 20000, 0, 1)
            hBarFill.Size = UDim2.new(pct, 0, 1, 0)

            -- determine zone
            local targetMode
            if h > THRESH_HIGH then
                targetMode = "WINS"
            elseif h < THRESH_LOW then
                targetMode = "SPEED"
            else
                targetMode = "IDLE"
            end

            applyMode(targetMode, h)
            task.wait(STATE.pushDelay)
        end
    end)
end

local function stopLoop()
    STATE.running = false
    if STATE.loop then task.cancel(STATE.loop); STATE.loop = nil end
    STATE.currentMode = "IDLE"
    StatusLbl.Text      = "● MATI"
    StatusLbl.TextColor3 = Color3.fromRGB(255, 80, 80)
    TogBtn.Text         = "▶ AKTIFKAN"
    togGrad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(60, 210, 115)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(30, 140, 65)),
    })
    RunLbl.Text      = "Menunggu diaktifkan..."
    RunLbl.TextColor3 = Color3.fromRGB(100, 96, 136)
    ModeIconLbl.Text = "〰"
    HeightZoneLbl.Text      = "〰 NORMAL"
    HeightZoneLbl.TextColor3 = Color3.fromRGB(130, 125, 170)
    fStroke.Color   = Color3.fromRGB(255, 215, 0)
    scSt.Color      = Color3.fromRGB(255, 215, 0)
    WinsStroke.Transparency  = 0.6
    SpeedStroke.Transparency = 0.6
    stopParticles()
    addLog("Loop dihentikan.", Color3.fromRGB(255, 80, 80))
    showToast("⏹ Push Trophy dimatikan", "⏹", Color3.fromRGB(255, 80, 80))
end

TogBtn.MouseButton1Click:Connect(function()
    if STATE.running then
        stopLoop()
    else
        startLoop()
    end
end)

