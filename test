local function makeThresholdCard(icon, accentColor, label, cfgKey, layoutOrder)

    local card = Instance.new("Frame", Body)
    card.Size=UDim2.new(1,0,0,100); card.BackgroundColor3=Color3.fromRGB(11,9,20)
    card.BorderSizePixel=0; card.ZIndex=103; card.LayoutOrder=layoutOrder
    Instance.new("UICorner", card).CornerRadius = UDim.new(0,14)

    local cs = Instance.new("UIStroke", card)
    cs.Color=accentColor; cs.Thickness=1.4; cs.Transparency=0.5

    local cardGrad = Instance.new("UIGradient", card)
    cardGrad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0,Color3.fromRGB(18,15,32)),
        ColorSequenceKeypoint.new(1,Color3.fromRGB(9,8,18)),
    })

    -- left accent bar
    local strip = Instance.new("Frame", card)
    strip.Size=UDim2.new(0,4,0.7,0); strip.Position=UDim2.new(0,0,0.15,0)
    strip.BackgroundColor3=accentColor; strip.BorderSizePixel=0
    Instance.new("UICorner", strip).CornerRadius = UDim.new(1,0)

    -- icon
    local ico = Instance.new("TextLabel", card)
    ico.Size=UDim2.new(0,36,0,36); ico.Position=UDim2.new(0,12,0,10)
    ico.BackgroundTransparency=1; ico.Text=icon; ico.TextSize=20
    ico.Font=Enum.Font.GothamBold; ico.ZIndex=104

    -- label souvenir
    local nameLbl = Instance.new("TextLabel", card)
    nameLbl.Size=UDim2.new(0.46,0,0,18); nameLbl.Position=UDim2.new(0,54,0,10)
    nameLbl.BackgroundTransparency=1; nameLbl.Text=label
    nameLbl.TextColor3=accentColor; nameLbl.TextSize=12
    nameLbl.Font=Enum.Font.GothamBold; nameLbl.TextXAlignment=Enum.TextXAlignment.Left; nameLbl.ZIndex=104

    -- ── ABOVE / BELOW TOGGLE ──
    local modeFrame = Instance.new("Frame", card)
    modeFrame.Size=UDim2.new(0,146,0,28); modeFrame.Position=UDim2.new(1,-154,0,8)
    modeFrame.BackgroundColor3=Color3.fromRGB(20,18,34); modeFrame.BorderSizePixel=0; modeFrame.ZIndex=104
    Instance.new("UICorner", modeFrame).CornerRadius = UDim.new(0,8)
    Instance.new("UIStroke", modeFrame).Color=Color3.fromRGB(50,44,80)

    -- slider pill inside
    local modePill = Instance.new("Frame", modeFrame)
    modePill.Size=UDim2.new(0.5,0,1,0); modePill.Position=UDim2.new(0,0,0,0)
    modePill.BackgroundColor3=accentColor; modePill.BackgroundTransparency=0.25
    modePill.BorderSizePixel=0; modePill.ZIndex=105
    Instance.new("UICorner", modePill).CornerRadius = UDim.new(0,8)

    local aboveLbl = Instance.new("TextLabel", modeFrame)
    aboveLbl.Size=UDim2.new(0.5,0,1,0); aboveLbl.Position=UDim2.new(0,0,0,0)
    aboveLbl.BackgroundTransparency=1; aboveLbl.Text="▲ DIATAS"
    aboveLbl.TextColor3=Color3.fromRGB(255,255,255); aboveLbl.TextSize=9
    aboveLbl.Font=Enum.Font.GothamBold; aboveLbl.ZIndex=106

    local belowLbl = Instance.new("TextLabel", modeFrame)
    belowLbl.Size=UDim2.new(0.5,0,1,0); belowLbl.Position=UDim2.new(0.5,0,0,0)
    belowLbl.BackgroundTransparency=1; belowLbl.Text="▼ DIBAWAH"
    belowLbl.TextColor3=Color3.fromRGB(130,120,165); belowLbl.TextSize=9
    belowLbl.Font=Enum.Font.GothamBold; belowLbl.ZIndex=106

    local modeBtn = Instance.new("TextButton", modeFrame)
    modeBtn.Size=UDim2.new(1,0,1,0); modeBtn.BackgroundTransparency=1
    modeBtn.Text=""; modeBtn.ZIndex=107

    -- ── NILAI (TextBox) ──
    local valRow = Instance.new("Frame", card)
    valRow.Size=UDim2.new(1,-20,0,38); valRow.Position=UDim2.new(0,10,0,52)
    valRow.BackgroundTransparency=1; valRow.ZIndex=104

    local valBg = Instance.new("Frame", valRow)
    valBg.Size=UDim2.new(0.56,0,1,0); valBg.Position=UDim2.new(0,0,0,0)
    valBg.BackgroundColor3=Color3.fromRGB(14,12,26); valBg.BorderSizePixel=0; valBg.ZIndex=104
    Instance.new("UICorner", valBg).CornerRadius = UDim.new(0,9)
    local valStroke = Instance.new("UIStroke", valBg)
    valStroke.Color=accentColor; valStroke.Thickness=1.2; valStroke.Transparency=0.55

    local valPrefix = Instance.new("TextLabel", valBg)
    valPrefix.Size=UDim2.new(0,28,1,0); valPrefix.Position=UDim2.new(0,6,0,0)
    valPrefix.BackgroundTransparency=1; valPrefix.Text="📏"
    valPrefix.TextSize=14; valPrefix.Font=Enum.Font.GothamBold; valPrefix.ZIndex=105

    local valBox = Instance.new("TextBox", valBg)
    valBox.Size=UDim2.new(1,-36,1,0); valBox.Position=UDim2.new(0,34,0,0)
    valBox.BackgroundTransparency=1; valBox.Text=tostring(CFG[cfgKey].value)
    valBox.TextColor3=accentColor; valBox.PlaceholderText="0"
    valBox.PlaceholderColor3=Color3.fromRGB(80,70,110)
    valBox.TextSize=14; valBox.Font=Enum.Font.GothamBold
    valBox.TextXAlignment=Enum.TextXAlignment.Left
    valBox.ClearTextOnFocus=false; valBox.ZIndex=106

    -- kondisi preview label (e.g. "aktif jika Y > 14000")
    local condLbl = Instance.new("TextLabel", valRow)
    condLbl.Size=UDim2.new(0.42,0,1,0); condLbl.Position=UDim2.new(0.57,0,0,0)
    condLbl.BackgroundTransparency=1
    condLbl.TextColor3=Color3.fromRGB(120,115,160); condLbl.TextSize=9
    condLbl.Font=Enum.Font.Gotham; condLbl.TextWrapped=true
    condLbl.TextXAlignment=Enum.TextXAlignment.Left; condLbl.ZIndex=104

    -- ── local state & update ──
    local cfg = CFG[cfgKey]

    local function updateUI()
        local modeIsAbove = (cfg.mode == "above")
        local pillX = modeIsAbove and 0 or 0.5
        tw(modePill, {Position=UDim2.new(pillX,0,0,0)}, 0.22, Enum.EasingStyle.Quad)
        aboveLbl.TextColor3 = modeIsAbove and Color3.fromRGB(255,255,255) or Color3.fromRGB(130,120,165)
        belowLbl.TextColor3 = modeIsAbove and Color3.fromRGB(130,120,165) or Color3.fromRGB(255,255,255)

        local sym = modeIsAbove and ">" or "<"
        local modeWord = modeIsAbove and "DIATAS" or "DIBAWAH"
        condLbl.Text = "aktif jika\nY "..sym.." "..tostring(cfg.value)

        -- stroke highlight
        cs.Transparency = 0.35
        tw(cs, {Transparency=0.55}, 0.4)
    end

    -- toggle mode
    modeBtn.MouseButton1Click:Connect(function()
        cfg.mode = (cfg.mode == "above") and "below" or "above"
        updateUI()
        if STATE.running then
            STATE.currentMode = "IDLE"  -- force re-evaluate
        end
        showToast(label.." → "..(cfg.mode=="above" and "▲ DIATAS" or "▼ DIBAWAH").." "..tostring(cfg.value), icon, accentColor)
    end)

    -- validate & apply textbox
    local function applyVal()
        local raw = valBox.Text:gsub("[^%d%-]","")
        local num = tonumber(raw)
        if num then
            cfg.value = num
            valBox.Text = tostring(num)
        else
            valBox.Text = tostring(cfg.value)
        end
        updateUI()
        if STATE.running then STATE.currentMode = "IDLE" end
    end

    valBox.FocusLost:Connect(applyVal)

    -- +/- quick buttons
    local function makeQuick(sym, col, xOff, delta)
        local qb = Instance.new("TextButton", valRow)
        qb.Size=UDim2.new(0,30,0,30); qb.Position=UDim2.new(0.57,xOff,0.5,-15)
        qb.BackgroundColor3=col; qb.Text=sym; qb.TextColor3=Color3.fromRGB(255,255,255)
        qb.TextSize=14; qb.Font=Enum.Font.GothamBold; qb.BorderSizePixel=0; qb.ZIndex=105
        Instance.new("UICorner", qb).CornerRadius = UDim.new(0,7)
        qb.MouseButton1Click:Connect(function()
            cfg.value = cfg.value + delta
            valBox.Text = tostring(cfg.value)
            updateUI()
            if STATE.running then STATE.currentMode = "IDLE" end
        end)
        return qb
    end

    -- quick +100 / -100
    makeQuick("-100", Color3.fromRGB(120,35,35), 0,    -100)
    makeQuick("+100", Color3.fromRGB(35,120,65), 36,   100)
    -- quick +1000 / -1000
    makeQuick("-1k",  Color3.fromRGB(90,30,30),  78,   -1000)
    makeQuick("+1k",  Color3.fromRGB(28,95,55),  114,  1000)

    updateUI()

    return card, cs, condLbl
end

