-- resize drag
do
    local resizing    = false
    local resizeStart = Vector2.zero
    local startW, startH = GUI_W, GUI_H

    ResizeHandle.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            resizing    = true
            resizeStart = Vector2.new(i.Position.X, i.Position.Y)
            startW      = Frame.AbsoluteSize.X
            startH      = Frame.AbsoluteSize.Y
            tw(ResizeHandle, {BackgroundColor3 = Color3.fromRGB(55, 42, 95)}, 0.1)
        end
    end)

    UIS.InputChanged:Connect(function(i)
        if resizing and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
            local d    = Vector2.new(i.Position.X, i.Position.Y) - resizeStart
            local newW = math.clamp(startW + d.X, GUI_MIN_W, GUI_MAX_W)
            local newH = math.clamp(startH + d.Y, GUI_MIN_H, GUI_MAX_H)
            if not STATE.minimized then
                Frame.Size = UDim2.new(0, newW, 0, newH)
                GUI_W = newW
                GUI_H = newH
            end
        end
    end)

    UIS.InputEnded:Connect(function(i)
        if (i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch) and resizing then
            resizing = false
            tw(ResizeHandle, {BackgroundColor3 = Color3.fromRGB(28, 24, 48)}, 0.15)
        end
    end)
end

