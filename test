local FIREWORK_COLORS = {
    Color3.fromRGB(255, 220, 50),
    Color3.fromRGB(255, 100, 80),
    Color3.fromRGB(80,  210, 255),
    Color3.fromRGB(180, 80,  255),
    Color3.fromRGB(80,  255, 140),
    Color3.fromRGB(255, 160, 50),
}

local function spawnFireworkBurst(cx, cy, color)
    local numSparks = math.random(14, 22)
    for _ = 1, numSparks do
        local angle  = math.random() * math.pi * 2
        local speed  = math.random(60, 160)
        local size   = math.random(4, 9)
        local life   = math.random(60, 110) / 100

        local spark = Instance.new("Frame", ParticleLayer)
        spark.Size                  = UDim2.new(0, size, 0, size)
        spark.Position              = UDim2.new(0, cx - size/2, 0, cy - size/2)
        spark.BackgroundColor3      = color
        spark.BackgroundTransparency = 0
        spark.BorderSizePixel       = 0
        spark.ZIndex                = 51
        Instance.new("UICorner", spark).CornerRadius = UDim.new(1, 0)

        local tx = cx + math.cos(angle) * speed
        local ty = cy + math.sin(angle) * speed

        tween(spark, {
            Position             = UDim2.new(0, tx - size/2, 0, ty - size/2),
            BackgroundTransparency = 1,
            Size                 = UDim2.new(0, 1, 0, 1),
        }, life, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

        task.delay(life, function()
            if spark and spark.Parent then spark:Destroy() end
        end)
    end
    -- center flash
    local flash = Instance.new("Frame", ParticleLayer)
    flash.Size                  = UDim2.new(0, 18, 0, 18)
    flash.Position              = UDim2.new(0, cx - 9, 0, cy - 9)
    flash.BackgroundColor3      = Color3.fromRGB(255, 255, 255)
    flash.BackgroundTransparency = 0
    flash.BorderSizePixel       = 0
    flash.ZIndex                = 52
    Instance.new("UICorner", flash).CornerRadius = UDim.new(1, 0)
    tween(flash, {BackgroundTransparency = 1, Size = UDim2.new(0, 40, 0, 40), Position = UDim2.new(0, cx-20, 0, cy-20)}, 0.35)
    task.delay(0.36, function() if flash.Parent then flash:Destroy() end end)
end

local function launchFirework()
    local vp = workspace.CurrentCamera.ViewportSize
    local cx  = math.random(80, vp.X - 80)
    local cy  = math.random(80, vp.Y - 80)
    local col = FIREWORK_COLORS[math.random(1, #FIREWORK_COLORS)]

    -- trail dot rising
    local trail = Instance.new("Frame", ParticleLayer)
    trail.Size                  = UDim2.new(0, 5, 0, 5)
    trail.Position              = UDim2.new(0, cx, 0, vp.Y)
    trail.BackgroundColor3      = col
    trail.BackgroundTransparency = 0.2
    trail.BorderSizePixel       = 0
    trail.ZIndex                = 51
    Instance.new("UICorner", trail).CornerRadius = UDim.new(1, 0)

    tween(trail, {Position = UDim2.new(0, cx, 0, cy)}, 0.45, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    task.delay(0.46, function()
        if trail.Parent then trail:Destroy() end
        spawnFireworkBurst(cx, cy, col)
        -- secondary smaller burst
        task.delay(0.08, function()
            local off = math.random(20, 40)
            spawnFireworkBurst(cx + off, cy - off, FIREWORK_COLORS[math.random(1, #FIREWORK_COLORS)])
        end)
    end)
end

-- Continuous ambient sparks (api kecil melayang)
local function spawnAmbientSpark()
    local vp  = workspace.CurrentCamera.ViewportSize
    local x   = math.random(0, vp.X)
    local col = FIREWORK_COLORS[math.random(1, #FIREWORK_COLORS)]
    local sz  = math.random(2, 6)
    local sp  = Instance.new("Frame", ParticleLayer)
    sp.Size                  = UDim2.new(0, sz, 0, sz)
    sp.Position              = UDim2.new(0, x, 1, 0)
    sp.BackgroundColor3      = col
    sp.BackgroundTransparency = 0.3
    sp.BorderSizePixel       = 0
    sp.ZIndex                = 50
    Instance.new("UICorner", sp).CornerRadius = UDim.new(1, 0)

    local destY  = math.random(-50, -vp.Y)
    local destX  = x + math.random(-60, 60)
    local lifeT  = math.random(15, 35) / 10

    tween(sp, {
        Position             = UDim2.new(0, destX, 0, destY),
        BackgroundTransparency = 1,
        Size                 = UDim2.new(0, 1, 0, 1),
    }, lifeT, Enum.EasingStyle.Sine)

    task.delay(lifeT, function()
        if sp and sp.Parent then sp:Destroy() end
    end)
end

-- Particle runner
local particleActive = false
local function startParticles()
    if particleActive then return end
    particleActive = true
    task.spawn(function()
        while particleActive do
            spawnAmbientSpark()
            task.wait(math.random(5, 15) / 100)
        end
    end)
    task.spawn(function()
        while particleActive do
            launchFirework()
            task.wait(math.random(8, 18) / 10)
        end
    end)
end
local function stopParticles()
    particleActive = false
end

