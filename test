        local old = table.remove(logLines,1)
        if old and old.Parent then old:Destroy() end
    end
    logOrder += 1
    local l = Instance.new("TextLabel", LogCard)
    l.Size=UDim2.new(1,0,0,16); l.BackgroundTransparency=1
