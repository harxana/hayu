local function addLog(msg, col)
    col = col or Color3.fromRGB(130, 125, 170)
    if #logLines >= 3 then
        local oldest = logLines[1]
        table.remove(logLines, 1)
        if oldest and oldest.Parent then oldest:Destroy() end
    end
    logOrder += 1
    local l = Instance.new("TextLabel", LogCard)
    l.Size               = UDim2.new(1, 0, 0, 16)
    l.BackgroundTransparency = 1
    l.Text               = "› " .. msg
    l.TextColor3         = col
    l.TextSize           = 8
    l.Font               = Enum.Font.Gotham
    l.TextXAlignment     = Enum.TextXAlignment.Left
    l.ZIndex             = 104
    l.LayoutOrder        = logOrder
    table.insert(logLines, l)
end

