    icoLbl.ZIndex             = 201

    local msgLbl = Instance.new("TextLabel", toast)
    msgLbl.Size               = UDim2.new(1, -54, 1, 0)
    msgLbl.Position           = UDim2.new(0, 48, 0, 0)
    msgLbl.BackgroundTransparency = 1
    msgLbl.Text               = msg
    msgLbl.TextColor3         = Color3.fromRGB(230, 225, 255)
    msgLbl.TextSize           = 11
    msgLbl.Font               = Enum.Font.GothamBold
    msgLbl.TextXAlignment     = Enum.TextXAlignment.Left
    msgLbl.TextWrapped        = true
    msgLbl.ZIndex             = 201

    local bar = Instance.new("Frame", toast)
    bar.Size            = UDim2.new(1, 0, 0, 3)
    bar.Position        = UDim2.new(0, 0, 1, -3)
    bar.BackgroundColor3 = col
    bar.BorderSizePixel = 0
