    Instance.new("UICorner", bar).CornerRadius = UDim.new(1, 0)

    -- slide in
    tween(toast, {Position = UDim2.new(0.5, -140, 0, 16)}, 0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
