-- MAIN LOOP
-- ══════════════════════════════════════════════
local function startLoop()
    STATE.running=true; STATE.currentMode="IDLE"
    StatusLbl.Text="● AKTIF"; StatusLbl.TextColor3=Color3.fromRGB(80,255,130)
    TogBtn.Text="■ MATIKAN"
    togGrad.Color=ColorSequence.new({
        ColorSequenceKeypoint.new(0,Color3.fromRGB(220,65,65)),
        ColorSequenceKeypoint.new(1,Color3.fromRGB(160,35,35)),
    })
    startParticles()
    showToast("🚀 Push Trophy aktif!","🚀",Color3.fromRGB(80,255,130))
    addLog("Loop dimulai!", Color3.fromRGB(80,255,130))

    STATE.loop = task.spawn(function()
        while STATE.running do
            local h = getHeight()
            STATE.lastHeight = h
            HeightValLbl.Text = math.floor(h).." studs"
            hBarFill.Size = UDim2.new(math.clamp(h/20000,0,1),0,1,0)

            -- cek WINS dulu, lalu SPEED (WINS prioritas lebih tinggi)
            local targetMode
            if checkCondition(CFG.wins,  h) then
                targetMode = "WINS"
            elseif checkCondition(CFG.speed, h) then
                targetMode = "SPEED"
            else
                targetMode = "IDLE"
            end

            applyMode(targetMode, h)
            task.wait(0.5)
        end
    end)
end

local function stopLoop()
    STATE.running=false
    if STATE.loop then task.cancel(STATE.loop); STATE.loop=nil end
    STATE.currentMode="IDLE"
    StatusLbl.Text="● MATI"; StatusLbl.TextColor3=Color3.fromRGB(255,80,80)
    TogBtn.Text="▶ AKTIFKAN"
    togGrad.Color=ColorSequence.new({
        ColorSequenceKeypoint.new(0,Color3.fromRGB(60,210,115)),
        ColorSequenceKeypoint.new(1,Color3.fromRGB(30,140,65)),
    })
    RunLbl.Text="Menunggu diaktifkan..."; RunLbl.TextColor3=Color3.fromRGB(100,96,136)
    ModeIconLbl.Text="〰"
    HeightZoneLbl.Text="〰 NORMAL"; HeightZoneLbl.TextColor3=Color3.fromRGB(130,125,170)
    fStroke.Color=Color3.fromRGB(255,215,0); scSt.Color=Color3.fromRGB(255,215,0)
    WinsCS.Transparency=0.5; SpeedCS.Transparency=0.5
    stopParticles()
    addLog("Loop dihentikan.", Color3.fromRGB(255,80,80))
