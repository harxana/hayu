local function applyMode(mode, h)
    if mode == STATE.currentMode then return end
    STATE.currentMode = mode

    if mode == "WINS" then
        fireSouvenirWins()
        STATE.winsCount += 1
        PushCountLbl.Text = tostring(STATE.winsCount)
        tw(PushCountLbl, {TextColor3=Color3.fromRGB(255,255,120)}, 0.08)
        task.delay(0.12, function() tw(PushCountLbl,{TextColor3=Color3.fromRGB(255,220,55)},0.3) end)

        local sym = CFG.wins.mode=="above" and ">" or "<"
        HeightZoneLbl.Text="🏆 WINS ZONE"; HeightZoneLbl.TextColor3=Color3.fromRGB(255,215,0)
        ModeIconLbl.Text="🏆"
        RunLbl.Text="WINS  Y"..sym..CFG.wins.value.."  ["..math.floor(h).."]"
        RunLbl.TextColor3=Color3.fromRGB(255,215,0)
        hBarFill.BackgroundColor3=Color3.fromRGB(255,215,0)
        fStroke.Color=Color3.fromRGB(255,215,0); scSt.Color=Color3.fromRGB(255,215,0)
        hcBarL.BackgroundColor3=Color3.fromRGB(255,215,0)
        WinsCS.Transparency=0.08; SpeedCS.Transparency=0.82
        addLog("🏆 WINS #"..STATE.winsCount.." @ "..math.floor(h).." studs", Color3.fromRGB(255,215,0))
        showToast("🏆 WINS Aktif!  Total: "..STATE.winsCount.."x","🏆",Color3.fromRGB(255,215,0))
        launchFirework(); task.delay(0.28,launchFirework); task.delay(0.56,launchFirework)

    elseif mode == "SPEED" then
        fireSouvenirSpeed()
        local sym = CFG.speed.mode=="above" and ">" or "<"
        HeightZoneLbl.Text="⚡ SPEED ZONE"; HeightZoneLbl.TextColor3=Color3.fromRGB(80,180,255)
        ModeIconLbl.Text="⚡"
        RunLbl.Text="SPEED  Y"..sym..CFG.speed.value.."  ["..math.floor(h).."]"
        RunLbl.TextColor3=Color3.fromRGB(80,200,255)
        hBarFill.BackgroundColor3=Color3.fromRGB(80,180,255)
        fStroke.Color=Color3.fromRGB(80,180,255); scSt.Color=Color3.fromRGB(80,180,255)
        hcBarL.BackgroundColor3=Color3.fromRGB(80,180,255)
        SpeedCS.Transparency=0.08; WinsCS.Transparency=0.82
        addLog("⚡ SPEED @ "..math.floor(h).." studs", Color3.fromRGB(80,200,255))
        showToast("⚡ SPEED Aktif!","⚡",Color3.fromRGB(80,180,255))
        launchFirework(); task.delay(0.22,launchFirework)

    else
        HeightZoneLbl.Text="〰 NORMAL"; HeightZoneLbl.TextColor3=Color3.fromRGB(130,125,170)
        ModeIconLbl.Text="〰"
        RunLbl.Text="Memantau ketinggian..."; RunLbl.TextColor3=Color3.fromRGB(100,96,136)
        fStroke.Color=Color3.fromRGB(255,215,0); scSt.Color=Color3.fromRGB(255,215,0)
        hcBarL.BackgroundColor3=Color3.fromRGB(255,215,0)
        WinsCS.Transparency=0.5; SpeedCS.Transparency=0.5
        addLog("Normal zone @ "..math.floor(h).." studs", Color3.fromRGB(130,125,170))
    end
end

