    end)
    task.delay(3.0, function()
        tween(toast, {Position = UDim2.new(0.5, -140, 0, -60), BackgroundTransparency = 1}, 0.35)
        tween(ts, {Transparency = 1}, 0.35)
        task.delay(0.36, function()
            if toast.Parent then toast:Destroy() end
        end)
    end)
end

