-- ================================================
-- SAFE WAIT
-- ================================================
local function safeWait(t)
    t = t or 0
    local s = tick()
    while tick() - s < t do
        RunService.Heartbeat:Wait()
    end
end

-- ================================================
-- SMART DELAY (ANTI DETECT)
-- ================================================
local function smartDelay(base)
    local jitter = base * 0.15
    local j = math.floor(jitter * 100)
    local delay = base + (j > 0 and (math.random(-j, j) / 100) or 0)
    safeWait(math.max(delay, 0.05))
end

