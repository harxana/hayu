local function showToast(msg, icon, col)
    local toast=Instance.new("Frame",ScreenGui)
    toast.Size=UDim2.new(0,300,0,54); toast.Position=UDim2.new(0.5,-150,0,-64)
    toast.BackgroundColor3=Color3.fromRGB(12,10,22); toast.BackgroundTransparency=0
