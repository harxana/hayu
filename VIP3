-- ================================================
-- DRAG SYSTEM
-- ================================================
do
    local dragging, dragStart, startPos = false, Vector2.zero, Frame.Position
    Frame.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then
            local abs = Frame.AbsolutePosition
            local sz  = Frame.AbsoluteSize
            local mx, my = inp.Position.X, inp.Position.Y
            local margin = 10
            if (mx < abs.X+margin) or (mx > abs.X+sz.X-margin)
            or (my < abs.Y+margin) or (my > abs.Y+sz.Y-margin) then return end
            dragging  = true
            dragStart = Vector2.new(mx, my)
            startPos  = Frame.Position
        end
    end)
    UIS.InputChanged:Connect(function(inp)
        if dragging and (inp.UserInputType == Enum.UserInputType.MouseMovement
                      or inp.UserInputType == Enum.UserInputType.Touch) then
            local d = Vector2.new(inp.Position.X, inp.Position.Y) - dragStart
            Frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset+d.X,
                                        startPos.Y.Scale, startPos.Y.Offset+d.Y)
        end
    end)
    UIS.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then dragging = false end
    end)
end

-- ================================================
-- RESIZE SYSTEM
-- ================================================
do
    local MIN_W, MIN_H = 280, 340
    local HANDLE_SIZE  = 10
    local handles = {
        {name="N",  x=HANDLE_SIZE, y=0,            w=-2*HANDLE_SIZE, h=HANDLE_SIZE,    dir=1},
        {name="S",  x=HANDLE_SIZE, y=-HANDLE_SIZE, w=-2*HANDLE_SIZE, h=HANDLE_SIZE,    dir=2},
        {name="W",  x=0,           y=HANDLE_SIZE,  w=HANDLE_SIZE,    h=-2*HANDLE_SIZE, dir=4},
        {name="E",  x=-HANDLE_SIZE,y=HANDLE_SIZE,  w=HANDLE_SIZE,    h=-2*HANDLE_SIZE, dir=8},
        {name="NW", x=0,           y=0,            w=HANDLE_SIZE,    h=HANDLE_SIZE,    dir=5},
        {name="NE", x=-HANDLE_SIZE,y=0,            w=HANDLE_SIZE,    h=HANDLE_SIZE,    dir=9},
        {name="SW", x=0,           y=-HANDLE_SIZE, w=HANDLE_SIZE,    h=HANDLE_SIZE,    dir=6},
        {name="SE", x=-HANDLE_SIZE,y=-HANDLE_SIZE, w=HANDLE_SIZE,    h=HANDLE_SIZE,    dir=10},
    }
    local cursorMap = {
        N="rbxasset://SystemCursors/SizeNS", S="rbxasset://SystemCursors/SizeNS",
        W="rbxasset://SystemCursors/SizeEW", E="rbxasset://SystemCursors/SizeEW",
        NW="rbxasset://SystemCursors/SizeNWSE", SE="rbxasset://SystemCursors/SizeNWSE",
        NE="rbxasset://SystemCursors/SizeNESW", SW="rbxasset://SystemCursors/SizeNESW",
    }
    local resizing, resizeDir = false, 0
    local resizeStart, origPos, origSize = Vector2.zero, Frame.Position, Frame.Size

    for _, h in ipairs(handles) do
        local hf = Instance.new("TextButton", Frame)
        local anchorX = (h.x < 0) and 1 or 0
        local anchorY = (h.y < 0) and 1 or 0
        hf.AnchorPoint  = Vector2.new(anchorX, anchorY)
        hf.Position     = UDim2.new(anchorX, h.x<0 and 0 or h.x, anchorY, h.y<0 and 0 or h.y)
        hf.Size         = UDim2.new(0, math.abs(h.w), 0, math.abs(h.h))
        hf.BackgroundTransparency = 1
        hf.Text = ""; hf.ZIndex = 200; hf.BorderSizePixel = 0; hf.Active = true
        local dir, name = h.dir, h.name
        hf.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1
            or inp.UserInputType == Enum.UserInputType.Touch then
                resizing=true; resizeDir=dir
                resizeStart=Vector2.new(inp.Position.X, inp.Position.Y)
                origPos=Frame.Position; origSize=Frame.Size
            end
        end)
        hf.MouseEnter:Connect(function() pcall(function() UIS.MouseIcon=cursorMap[name] or "" end) end)
        hf.MouseLeave:Connect(function() if not resizing then pcall(function() UIS.MouseIcon="" end) end end)
    end

    UIS.InputChanged:Connect(function(inp)
        if not resizing then return end
        if inp.UserInputType ~= Enum.UserInputType.MouseMovement
        and inp.UserInputType ~= Enum.UserInputType.Touch then return end
        local vp = workspace.CurrentCamera.ViewportSize
        local dx = inp.Position.X - resizeStart.X
        local dy = inp.Position.Y - resizeStart.Y
        local opx,opy,osw,osh = origPos.X.Offset,origPos.Y.Offset,origSize.X.Offset,origSize.Y.Offset
        local newX,newY,newW,newH = opx,opy,osw,osh
        if resizeDir==1 or resizeDir==5 or resizeDir==9 then
            local c=osh-dy; if c>=MIN_H then newH=c; newY=opy+dy end
        end
        if resizeDir==2 or resizeDir==6 or resizeDir==10 then newH=math.max(osh+dy,MIN_H) end
        if resizeDir==4 or resizeDir==5 or resizeDir==6 then
            local c=osw-dx; if c>=MIN_W then newW=c; newX=opx+dx end
        end
        if resizeDir==8 or resizeDir==9 or resizeDir==10 then newW=math.max(osw+dx,MIN_W) end
        newW=math.min(newW,vp.X); newH=math.min(newH,vp.Y)
        newX=math.clamp(newX,0,vp.X-newW); newY=math.clamp(newY,0,vp.Y-newH)
        Frame.Position=UDim2.new(0,newX,0,newY); Frame.Size=UDim2.new(0,newW,0,newH)
    end)
    UIS.InputEnded:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.MouseButton1
        or inp.UserInputType==Enum.UserInputType.Touch then
            if resizing then resizing=false; pcall(function() UIS.MouseIcon="" end) end
        end
    end)
end

