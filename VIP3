local function checkCondition(cfg, h)
    if cfg.mode == "above" then
        return h > cfg.value
    else
        return h < cfg.value
    end
end

local function getTrophyHeight()
    local char = LocalPlayer.Character
    if char then
        local root = char:FindFirstChild("HumanoidRootPart")
        if root then return root.Position.Y end
    end
    return 0
end

