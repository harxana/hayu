local function applyMode(mode, h)
    if mode == TROPHY_STATE.currentMode then return end
    TROPHY_STATE.currentMode = mode

    if mode == "WINS" then
        fireSouvenirWins()
        TROPHY_STATE.winsCount += 1
        PushCountLbl.Text = tostring(TROPHY_STATE.winsCount)
        TweenService:Create(PushCountLbl, TweenInfo.new(0.08), {TextColor3=Color3.fromRGB(255,255,120)}):Play()
        task.delay(0.12, function() TweenService:Create(PushCountLbl,TweenInfo.new(0.3),{TextColor3=Color3.fromRGB(255,220,55)}):Play() end)

        local sym = CFG.wins.mode=="above" and ">" or "<"
        HeightZoneLbl.Text="🏆 WINS ZONE"; HeightZoneLbl.TextColor3=Color3.fromRGB(255,215,0)
        ModeIconLbl.Text="🏆"
        TrophyRunLbl.Text="WINS  Y"..sym..CFG.wins.value.."  ["..math.floor(h).."]"
        TrophyRunLbl.TextColor3=Color3.fromRGB(255,215,0)
        hBarFill.BackgroundColor3=Color3.fromRGB(255,215,0)
        _fStroke.Color=Color3.fromRGB(255,215,0); scSt.Color=Color3.fromRGB(255,215,0)
        hcBarL.BackgroundColor3=Color3.fromRGB(255,215,0)
        WinsCS.Transparency=0.08; SpeedCS.Transparency=0.82
        addLog("🏆 WINS #"..TROPHY_STATE.winsCount.." @ "..math.floor(h).." studs", Color3.fromRGB(255,215,0))
        showToast("🏆 WINS Aktif!  Total: "..TROPHY_STATE.winsCount.."x","🏆",Color3.fromRGB(255,215,0))
        launchFirework(); task.delay(0.28,launchFirework); task.delay(0.56,launchFirework)

    elseif mode == "SPEED" then
        fireSouvenirSpeed()
        local sym = CFG.speed.mode=="above" and ">" or "<"
        HeightZoneLbl.Text="⚡ SPEED ZONE"; HeightZoneLbl.TextColor3=Color3.fromRGB(80,180,255)
        ModeIconLbl.Text="⚡"
        TrophyRunLbl.Text="SPEED  Y"..sym..CFG.speed.value.."  ["..math.floor(h).."]"
        TrophyRunLbl.TextColor3=Color3.fromRGB(80,200,255)
        hBarFill.BackgroundColor3=Color3.fromRGB(80,180,255)
        _fStroke.Color=Color3.fromRGB(80,180,255); scSt.Color=Color3.fromRGB(80,180,255)
        hcBarL.BackgroundColor3=Color3.fromRGB(80,180,255)
        SpeedCS.Transparency=0.08; WinsCS.Transparency=0.82
        addLog("⚡ SPEED @ "..math.floor(h).." studs", Color3.fromRGB(80,200,255))
        showToast("⚡ SPEED Aktif!","⚡",Color3.fromRGB(80,180,255))
        launchFirework(); task.delay(0.22,launchFirework)

    else
        HeightZoneLbl.Text="〰 NORMAL"; HeightZoneLbl.TextColor3=Color3.fromRGB(130,125,170)
        ModeIconLbl.Text="〰"
        TrophyRunLbl.Text="Memantau ketinggian..."; TrophyRunLbl.TextColor3=Color3.fromRGB(100,96,136)
        _fStroke.Color=Color3.fromRGB(255,215,0); scSt.Color=Color3.fromRGB(255,215,0)
        hcBarL.BackgroundColor3=Color3.fromRGB(255,215,0)
        WinsCS.Transparency=0.5; SpeedCS.Transparency=0.5
        addLog("Normal zone @ "..math.floor(h).." studs", Color3.fromRGB(130,125,170))
    end
end

local function startTrophyLoop()
    TROPHY_STATE.running=true; TROPHY_STATE.currentMode="IDLE"
    TrophyStatusLbl.Text="● AKTIF"; TrophyStatusLbl.TextColor3=Color3.fromRGB(80,255,130)
    TrophyTogBtn.Text="■ MATIKAN"
    togGrad.Color=ColorSequence.new({
        ColorSequenceKeypoint.new(0,Color3.fromRGB(220,65,65)),
        ColorSequenceKeypoint.new(1,Color3.fromRGB(160,35,35)),
    })
    startParticles()
    showToast("🚀 Push Trophy aktif!","🚀",Color3.fromRGB(80,255,130))
    addLog("Loop dimulai!", Color3.fromRGB(80,255,130))

    TROPHY_STATE.loop = task.spawn(function()
        while TROPHY_STATE.running do
            local h = getTrophyHeight()
            TROPHY_STATE.lastHeight = h
            HeightValLbl.Text = math.floor(h).." studs"
            hBarFill.Size = UDim2.new(math.clamp(h/20000,0,1),0,1,0)

            local targetMode
            if checkCondition(CFG.wins, h) then
                targetMode = "WINS"
            elseif checkCondition(CFG.speed, h) then
                targetMode = "SPEED"
            else
                targetMode = "IDLE"
            end

            applyMode(targetMode, h)
            task.wait(0.5)
        end
    end)
end

local function stopTrophyLoop()
    TROPHY_STATE.running=false
    if TROPHY_STATE.loop then task.cancel(TROPHY_STATE.loop); TROPHY_STATE.loop=nil end
    TROPHY_STATE.currentMode="IDLE"
    TrophyStatusLbl.Text="● MATI"; TrophyStatusLbl.TextColor3=Color3.fromRGB(255,80,80)
    TrophyTogBtn.Text="▶ AKTIFKAN"
    togGrad.Color=ColorSequence.new({
        ColorSequenceKeypoint.new(0,Color3.fromRGB(60,210,115)),
        ColorSequenceKeypoint.new(1,Color3.fromRGB(30,140,65)),
    })
    TrophyRunLbl.Text="Menunggu diaktifkan..."; TrophyRunLbl.TextColor3=Color3.fromRGB(100,96,136)
    ModeIconLbl.Text="〰"
    HeightZoneLbl.Text="〰 NORMAL"; HeightZoneLbl.TextColor3=Color3.fromRGB(130,125,170)
    _fStroke.Color=Color3.fromRGB(255,175,0); scSt.Color=Color3.fromRGB(255,215,0)
    WinsCS.Transparency=0.5; SpeedCS.Transparency=0.5
    stopParticles()
    addLog("Loop dihentikan.", Color3.fromRGB(255,80,80))
    showToast("⏹ Push Trophy dimatikan","⏹",Color3.fromRGB(255,80,80))
end

TrophyTogBtn.MouseButton1Click:Connect(function()
