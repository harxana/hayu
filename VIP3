local function burst(cx, cy, color)
    for _ = 1, math.random(14, 22) do
        local angle = math.random() * math.pi * 2
        local spd   = math.random(60, 160)
        local sz    = math.random(4, 9)
        local life  = math.random(60, 110) / 100
        local s     = Instance.new("Frame", ParticleLayer)
        s.Size = UDim2.new(0,sz,0,sz); s.Position = UDim2.new(0,cx-sz/2,0,cy-sz/2)
        s.BackgroundColor3 = color; s.BackgroundTransparency = 0; s.BorderSizePixel = 0; s.ZIndex = 51
        Instance.new("UICorner", s).CornerRadius = UDim.new(1,0)
        TweenService:Create(s, TweenInfo.new(life, Enum.EasingStyle.Quad), {
            Position=UDim2.new(0,cx+math.cos(angle)*spd-sz/2,0,cy+math.sin(angle)*spd-sz/2),
            BackgroundTransparency=1, Size=UDim2.new(0,1,0,1)}):Play()
        task.delay(life, function() if s.Parent then s:Destroy() end end)
    end
    local fl = Instance.new("Frame", ParticleLayer)
    fl.Size=UDim2.new(0,18,0,18); fl.Position=UDim2.new(0,cx-9,0,cy-9)
    fl.BackgroundColor3=Color3.fromRGB(255,255,255); fl.BackgroundTransparency=0
    fl.BorderSizePixel=0; fl.ZIndex=52
    Instance.new("UICorner", fl).CornerRadius = UDim.new(1,0)
    TweenService:Create(fl, TweenInfo.new(0.35, Enum.EasingStyle.Quad), {BackgroundTransparency=1,Size=UDim2.new(0,40,0,40),Position=UDim2.new(0,cx-20,0,cy-20)}):Play()
    task.delay(0.36, function() if fl.Parent then fl:Destroy() end end)
end

local function launchFirework()
    local vp  = workspace.CurrentCamera.ViewportSize
    local cx  = math.random(80, vp.X-80)
    local cy  = math.random(80, vp.Y-80)
    local col = FW_COLORS[math.random(1,#FW_COLORS)]
    local tr  = Instance.new("Frame", ParticleLayer)
    tr.Size=UDim2.new(0,5,0,5); tr.Position=UDim2.new(0,cx,0,vp.Y)
    tr.BackgroundColor3=col; tr.BackgroundTransparency=0.2; tr.BorderSizePixel=0; tr.ZIndex=51
    Instance.new("UICorner", tr).CornerRadius = UDim.new(1,0)
    TweenService:Create(tr, TweenInfo.new(0.45, Enum.EasingStyle.Quad), {Position=UDim2.new(0,cx,0,cy)}):Play()
    task.delay(0.46, function()
        if tr.Parent then tr:Destroy() end
        burst(cx, cy, col)
        task.delay(0.08, function()
            local off = math.random(20,40)
            burst(cx+off, cy-off, FW_COLORS[math.random(1,#FW_COLORS)])
        end)
    end)
end

local function ambientSpark()
    local vp  = workspace.CurrentCamera.ViewportSize
    local x   = math.random(0, vp.X)
    local col = FW_COLORS[math.random(1,#FW_COLORS)]
    local sz  = math.random(2,6)
    local sp  = Instance.new("Frame", ParticleLayer)
    sp.Size=UDim2.new(0,sz,0,sz); sp.Position=UDim2.new(0,x,1,0)
    sp.BackgroundColor3=col; sp.BackgroundTransparency=0.3; sp.BorderSizePixel=0; sp.ZIndex=50
    Instance.new("UICorner", sp).CornerRadius = UDim.new(1,0)
    local lifeT = math.random(15,35)/10
    TweenService:Create(sp, TweenInfo.new(lifeT, Enum.EasingStyle.Sine), {
        Position=UDim2.new(0,x+math.random(-60,60),0,math.random(-50,-vp.Y)),
        BackgroundTransparency=1, Size=UDim2.new(0,1,0,1)}):Play()
    task.delay(lifeT, function() if sp.Parent then sp:Destroy() end end)
end

local particleActive = false
local function startParticles()
    if particleActive then return end
    particleActive = true
    task.spawn(function()
        while particleActive do ambientSpark(); task.wait(math.random(5,15)/100) end
    end)
    task.spawn(function()
        while particleActive do launchFirework(); task.wait(math.random(8,18)/10) end
    end)
end
local function stopParticles() particleActive = false end

