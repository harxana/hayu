local TABS = {
    souvenir   = {panel=PanelSouvenir,    tab=SvTab, color=Color3.fromRGB(255,190,0)},
    superauto  = {panel=PanelSuperAuto,   tab=SaTab, color=Color3.fromRGB(0,220,255)},
    hatch      = {panel=PanelHatch,       tab=HtTab, color=Color3.fromRGB(160,80,255)},
    pushtrophy = {panel=PanelPushTrophy,  tab=PtTab, color=Color3.fromRGB(255,215,0)},
}

local function switchTab(name)
    activeTab = name
    for k, t in pairs(TABS) do
        t.panel.Visible = (k == name)
        local active = (k == name)
        t.tab.indicator.Visible = active
        if active then
            t.tab.frame.BackgroundColor3 = Color3.fromRGB(26,22,42)
            t.tab.stroke.Transparency = 0.35
            t.tab.nameLbl.TextColor3 = t.tab.accent
        else
            t.tab.frame.BackgroundColor3 = Color3.fromRGB(20,17,32)
            t.tab.stroke.Transparency = 0.88
            t.tab.nameLbl.TextColor3 = Color3.fromRGB(110,106,144)
        end
    end
end

for k, t in pairs(TABS) do
    t.tab.btn.MouseButton1Click:Connect(function() switchTab(k) end)
end

