-- TAB SWITCH SYSTEM (top navbar)
-- ================================================
local allTabs   = {HtTab, PtTab, ApTab}
local allPanels = {PanelHatch, PanelPushTrophy, PanelAutoPet}

local function switchTab(idx)
    for i, tab in ipairs(allTabs) do
        local active = (i == idx)
        allPanels[i].Visible = active

        tab.indicator.Visible = active
        tab.frame.BackgroundColor3 = active
            and Color3.fromRGB(24,20,40)
            or  Color3.fromRGB(20,17,32)
        tab.stroke.Transparency = active and 0.25 or 0.88
        tab.nameLbl.TextColor3 = active
            and tab.accent
            or  Color3.fromRGB(110,106,144)
        tab.icoLbl.TextColor3 = active
            and Color3.fromRGB(255,255,255)
            or  Color3.fromRGB(150,140,180)
    end
    -- Reset scroll
    ContentScroll.CanvasPosition = Vector2.zero
end

HtTab.btn.MouseButton1Click:Connect(function()  switchTab(1) end)
PtTab.btn.MouseButton1Click:Connect(function()  switchTab(2) end)
ApTab.btn.MouseButton1Click:Connect(function()  switchTab(3) end)

