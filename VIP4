local function showToast(msg, icon, col)
    local toast = Instance.new("Frame", ScreenGui)
    toast.Size=UDim2.new(0,300,0,54); toast.Position=UDim2.new(0.5,-150,0,-64)
    toast.BackgroundColor3=Color3.fromRGB(12,10,22); toast.BackgroundTransparency=0
    toast.BorderSizePixel=0; toast.ZIndex=200
    Instance.new("UICorner", toast).CornerRadius = UDim.new(0,14)
    local ts = Instance.new("UIStroke", toast)
    ts.Color=col; ts.Thickness=1.8; ts.Transparency=0.15
    local ico = Instance.new("TextLabel", toast)
    ico.Size=UDim2.new(0,40,1,0); ico.Position=UDim2.new(0,6,0,0)
    ico.BackgroundTransparency=1; ico.Text=icon; ico.TextSize=24
    ico.Font=Enum.Font.GothamBold; ico.ZIndex=201
    local ml = Instance.new("TextLabel", toast)
    ml.Size=UDim2.new(1,-52,1,0); ml.Position=UDim2.new(0,50,0,0)
    ml.BackgroundTransparency=1; ml.Text=msg; ml.TextColor3=Color3.fromRGB(235,230,255)
    ml.TextSize=10; ml.Font=Enum.Font.GothamBold
    ml.TextXAlignment=Enum.TextXAlignment.Left; ml.TextWrapped=true; ml.ZIndex=201
    local bar = Instance.new("Frame", toast)
    bar.Size=UDim2.new(1,0,0,3); bar.Position=UDim2.new(0,0,1,-3)
    bar.BackgroundColor3=col; bar.BorderSizePixel=0; bar.ZIndex=202
    Instance.new("UICorner", bar).CornerRadius = UDim.new(1,0)
    TweenService:Create(toast, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
        {Position=UDim2.new(0.5,-150,0,16)}):Play()
    task.delay(0.5, function() TweenService:Create(bar, TweenInfo.new(2.4, Enum.EasingStyle.Linear), {Size=UDim2.new(0,0,0,3)}):Play() end)
    task.delay(3.1, function()
        TweenService:Create(toast, TweenInfo.new(0.35), {Position=UDim2.new(0.5,-150,0,-64), BackgroundTransparency=1}):Play()
        TweenService:Create(ts, TweenInfo.new(0.35), {Transparency=1}):Play()
        task.delay(0.36, function() if toast.Parent then toast:Destroy() end end)
    end)
end

