local saClaimThread = nil

local function runClaimLoop()
    while saClaimAktif do
        for n = 1, 12 do
            if not saClaimAktif then break end
            pcall(function()
                local args = { "GetOnlineAward", n }
                RS:WaitForChild("Msg"):WaitForChild("RemoteEvent"):FireServer(table.unpack(args))
            end)
            smartDelay(3)
        end
        if not saClaimAktif then break end
        smartDelay(100)
    end
end

local function setClaimON()
    saClaimAktif = true
    ClaimCard.togBtn.Text = "ON"
    ClaimCard.togBtn.BackgroundColor3 = Color3.fromRGB(35,145,70)
    ClaimCard.togBtn.TextColor3 = Color3.fromRGB(255,255,255)
    ClaimCard.stroke.Transparency = 0.2
    ClaimCard.card.BackgroundColor3 = Color3.fromRGB(12,22,16)
    ClaimCard.strip.BackgroundTransparency = 0.2
    saClaimThread = task.spawn(runClaimLoop)
end

local function setClaimOFF()
    saClaimAktif = false
    if saClaimThread then task.cancel(saClaimThread); saClaimThread = nil end
    ClaimCard.togBtn.Text = "OFF"
    ClaimCard.togBtn.BackgroundColor3 = Color3.fromRGB(50,48,70)
    ClaimCard.togBtn.TextColor3 = Color3.fromRGB(140,136,170)
    ClaimCard.stroke.Transparency = 0.7
    ClaimCard.card.BackgroundColor3 = Color3.fromRGB(16,14,26)
    ClaimCard.strip.BackgroundTransparency = 0.7
end

ClaimCard.togBtn.MouseButton1Click:Connect(function()
    if saClaimAktif then setClaimOFF() else setClaimON() end
end)

