-- ================================================
-- SAFE WAIT
-- ================================================
local function safeWait(t)
    t = t or 0
    local s = tick()
    while tick() - s < t do
        RunService.Heartbeat:Wait()
    end
end

-- ================================================
-- SMART DELAY
-- ================================================
local function smartDelay(base)
    local jitter = base * 0.2
    local delay  = base + math.random(-math.floor(jitter * 100), math.floor(jitter * 100)) / 100
    safeWait(math.max(delay, 0.05))
end

