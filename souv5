    if mode == PT_STATE.currentMode then return end
    PT_STATE.currentMode = mode

    if mode == "WINS" then
        fireSouvenirWins()
        PT_STATE.winsCount += 1
        PTPushCountLbl.Text = tostring(PT_STATE.winsCount)
        ptTw(PTPushCountLbl,{TextColor3=Color3.fromRGB(255,255,120)},0.08)
