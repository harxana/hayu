    ClaimToggleBtn.Text="▶  NYALAKAN"; ClaimRunLbl.Text="Menunggu..."
    _clGrad.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(60,200,110)),ColorSequenceKeypoint.new(1,Color3.fromRGB(30,140,70))})
