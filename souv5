local function runClaimLoop()
    while claimAktif do
        for n=1,12 do
            if not claimAktif then break end
            if not claimActive[n] then if claimStatus[n] and claimStatus[n].Parent then claimStatus[n].Text="skip" end continue end
            ClaimRunLbl.Text="Mengambil Award #"..n
            if claimStatus[n] and claimStatus[n].Parent then claimStatus[n].Text="⏳"; claimStatus[n].TextColor3=Color3.fromRGB(255,210,60) end
            fireOnlineAward(n); task.wait(0.4)
            if claimStatus[n] and claimStatus[n].Parent then claimStatus[n].Text="✔"; claimStatus[n].TextColor3=Color3.fromRGB(80,230,130) end
            task.wait(0.3)
        end
        for t=claimDelay,1,-1 do
            if not claimAktif then break end
            ClaimRunLbl.Text="Ulang dalam "..t.." dtk"; task.wait(1)
        end
    end
    setClaimOFF()
end
