    local cardStroke = Instance.new("UIStroke", card)
    cardStroke.Thickness = 2
    cardStroke.Transparency = 1

    -- Gradient card
    local cardGrad = Instance.new("UIGradient", card)
    cardGrad.Rotation = 135

    -- Glow outer
    local glow = Instance.new("Frame", nGui)
    glow.Size = UDim2.new(0, 340, 0, 180)
    glow.Position = UDim2.new(0.5, -170, 0.3, -90)
    glow.BackgroundTransparency = 1
    glow.BorderSizePixel = 0
    glow.ZIndex = 9
    Instance.new("UICorner", glow).CornerRadius = UDim.new(0, 22)
    local glowStroke = Instance.new("UIStroke", glow)
    glowStroke.Thickness = 6
    glowStroke.Transparency = 1

    -- Icon circle
    local iconCirc = Instance.new("Frame", card)
    iconCirc.Size = UDim2.new(0, 54, 0, 54)
    iconCirc.Position = UDim2.new(0.5, -27, 0, 18)
    iconCirc.BackgroundTransparency = 0.75
    iconCirc.BorderSizePixel = 0
    iconCirc.ZIndex = 11
    Instance.new("UICorner", iconCirc).CornerRadius = UDim.new(1, 0)

    local iconLbl = Instance.new("TextLabel", iconCirc)
    iconLbl.Size = UDim2.new(1,0,1,0)
    iconLbl.BackgroundTransparency = 1
    iconLbl.TextSize = 26
    iconLbl.Font = Enum.Font.GothamBold
    iconLbl.ZIndex = 12

    -- Title
    local titleLbl = Instance.new("TextLabel", card)
    titleLbl.Size = UDim2.new(1,-20,0,24)
    titleLbl.Position = UDim2.new(0,10,0,80)
    titleLbl.BackgroundTransparency = 1
    titleLbl.TextSize = 15
    titleLbl.Font = Enum.Font.GothamBold
    titleLbl.TextXAlignment = Enum.TextXAlignment.Center
    titleLbl.ZIndex = 11

    -- Sub label
    local subLbl = Instance.new("TextLabel", card)
    subLbl.Size = UDim2.new(1,-20,0,32)
    subLbl.Position = UDim2.new(0,10,0,106)
    subLbl.BackgroundTransparency = 1
    subLbl.TextSize = 10
    subLbl.Font = Enum.Font.Gotham
    subLbl.TextXAlignment = Enum.TextXAlignment.Center
    subLbl.TextWrapped = true
    subLbl.ZIndex = 11

    -- Username label
    local userLbl = Instance.new("TextLabel", card)
    userLbl.Size = UDim2.new(1,-20,0,18)
    userLbl.Position = UDim2.new(0,10,0,57)
    userLbl.BackgroundTransparency = 1
    userLbl.Text = "@"..LocalPlayer.Name
    userLbl.TextSize = 10
    userLbl.Font = Enum.Font.Gotham
    userLbl.TextXAlignment = Enum.TextXAlignment.Center
    userLbl.ZIndex = 11

    -- Progress bar container
    local barBg = Instance.new("Frame", card)
    barBg.Size = UDim2.new(0.85,0,0,4)
    barBg.Position = UDim2.new(0.075,0,1,-10)
    barBg.BackgroundColor3 = Color3.fromRGB(30,28,50)
    barBg.BorderSizePixel = 0
    barBg.ZIndex = 11
    Instance.new("UICorner", barBg).CornerRadius = UDim.new(1,0)

    local barFill = Instance.new("Frame", barBg)
    barFill.Size = UDim2.new(0,0,1,0)
    barFill.BackgroundColor3 = Color3.fromRGB(255,255,255)
    barFill.BorderSizePixel = 0
    barFill.ZIndex = 12
    Instance.new("UICorner", barFill).CornerRadius = UDim.new(1,0)

    -- Particle dots (dekorasi)
    for i = 1, 5 do
        local dot = Instance.new("Frame", nGui)
        dot.Size = UDim2.new(0, math.random(4,8), 0, math.random(4,8))
        dot.Position = UDim2.new(0.5, math.random(-120,120), 0.3, math.random(-60,60))
        dot.BackgroundTransparency = 0.5
        dot.BorderSizePixel = 0
        dot.ZIndex = 8
        Instance.new("UICorner", dot).CornerRadius = UDim.new(1,0)

        if success then
            dot.BackgroundColor3 = Color3.fromRGB(80, 255, 150)
        else
            dot.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
        end

        -- Animasi dot
        task.spawn(function()
            local t1 = TweenService:Create(dot, TweenInfo.new(0.5, Enum.EasingStyle.Quad), {BackgroundTransparency=1, Size=UDim2.new(0,0,0,0)})
            task.wait(math.random(1,8)/10)
            t1:Play()
        end)
    end

    -- Isi konten berdasarkan status
    if success then
        iconCirc.BackgroundColor3 = Color3.fromRGB(40, 200, 100)
        iconLbl.Text = "✔"
        iconLbl.TextColor3 = Color3.fromRGB(180, 255, 210)
        titleLbl.Text = "Akses Diberikan!"
        titleLbl.TextColor3 = Color3.fromRGB(80, 255, 140)
        subLbl.Text = "Selamat datang di HAYU Store v4"
        subLbl.TextColor3 = Color3.fromRGB(120, 200, 160)
        userLbl.TextColor3 = Color3.fromRGB(80, 220, 130)
        cardStroke.Color = Color3.fromRGB(60, 220, 110)
        glowStroke.Color = Color3.fromRGB(60, 220, 110)
        barFill.BackgroundColor3 = Color3.fromRGB(60, 220, 110)
        cardGrad.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(14, 28, 20)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(8, 14, 12))
        })
    else
        iconCirc.BackgroundColor3 = Color3.fromRGB(200, 40, 40)
        iconLbl.Text = "✕"
        iconLbl.TextColor3 = Color3.fromRGB(255, 180, 180)
        titleLbl.Text = "Akses Ditolak!"
        titleLbl.TextColor3 = Color3.fromRGB(255, 80, 80)
        subLbl.Text = "Kamu tidak terdaftar di whitelist HAYU Store"
        subLbl.TextColor3 = Color3.fromRGB(200, 120, 120)
        userLbl.TextColor3 = Color3.fromRGB(220, 100, 100)
        cardStroke.Color = Color3.fromRGB(220, 55, 55)
        glowStroke.Color = Color3.fromRGB(220, 55, 55)
        barFill.BackgroundColor3 = Color3.fromRGB(220, 55, 55)
        cardGrad.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(28, 10, 10)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(14, 6, 6))
        })
    end

    -- ANIMASI MASUK
    card.BackgroundTransparency = 1
    card.Position = UDim2.new(0.5, -160, 0.2, -80)

    -- Fade in overlay
    TweenService:Create(overlay, TweenInfo.new(0.3), {BackgroundTransparency=0.72}):Play()

    -- Slide + fade in card
    TweenService:Create(card, TweenInfo.new(0.45, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Position = UDim2.new(0.5,-160,0.3,-80),
        BackgroundTransparency = 0
    }):Play()

    -- Stroke fade in
    TweenService:Create(cardStroke, TweenInfo.new(0.45), {Transparency=0.2}):Play()
    TweenService:Create(glowStroke, TweenInfo.new(0.6), {Transparency=0.78}):Play()

    -- Progress bar animasi
    task.delay(0.5, function()
        TweenService:Create(barFill, TweenInfo.new(2.5, Enum.EasingStyle.Linear), {
            Size = UDim2.new(1,0,1,0)
        }):Play()
    end)

    -- Pulse glow loop
    task.spawn(function()
        local dur = success and 3.2 or 3.2
        local t = 0
        while t < dur do
            TweenService:Create(glowStroke, TweenInfo.new(0.5), {Transparency=0.65}):Play()
            task.wait(0.5)
            TweenService:Create(glowStroke, TweenInfo.new(0.5), {Transparency=0.88}):Play()
            task.wait(0.5)
            t += 1
        end
    end)

    -- ANIMASI KELUAR setelah 3.2 detik
    task.delay(3.2, function()
        TweenService:Create(card, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
            Position = UDim2.new(0.5,-160,0.15,-80),
            BackgroundTransparency = 1
        }):Play()
        TweenService:Create(cardStroke, TweenInfo.new(0.4), {Transparency=1}):Play()
        TweenService:Create(glowStroke, TweenInfo.new(0.4), {Transparency=1}):Play()
        TweenService:Create(overlay, TweenInfo.new(0.4), {BackgroundTransparency=1}):Play()
        task.wait(0.45)
        nGui:Destroy()
    end)
end

