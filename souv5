local TABS={
    souvenir  ={panel=PanelSouvenir,   tab=SvTab,  color=Color3.fromRGB(255,190,0)},
    claim     ={panel=PanelClaim,      tab=ClTab,  color=Color3.fromRGB(80,180,255)},
