    delete    ={panel=PanelDelete,     tab=DlTab,  color=Color3.fromRGB(255,80,80)},
    pushtrophy={panel=PanelPushTrophy, tab=PtTab,  color=Color3.fromRGB(255,215,0)},
}

local function switchTab(name)
    activeTab=name
    for k,t in pairs(TABS) do
        t.panel.Visible=(k==name)
        local isActive=(k==name)
        t.tab.indicator.Visible=isActive
        if isActive then
            t.tab.frame.BackgroundColor3=Color3.fromRGB(24,20,38)
            t.tab.stroke.Transparency=0.4
            t.tab.nameLbl.TextColor3=t.tab.accent
        else
            t.tab.frame.BackgroundColor3=Color3.fromRGB(20,17,32)
            t.tab.stroke.Transparency=0.88
            t.tab.nameLbl.TextColor3=Color3.fromRGB(100,96,130)
        end
    end
    ContentScroll.CanvasPosition=Vector2.new(0,0)
end

