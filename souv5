-- ── MAIN LOOP ──
local function ptStartLoop()
    PT_STATE.running=true; PT_STATE.currentMode="IDLE"
    PTStatusLbl.Text="● AKTIF"; PTStatusLbl.TextColor3=Color3.fromRGB(80,255,130)
    PTTogBtn.Text="■ MATIKAN"
    ptTogGrad.Color=ColorSequence.new({
        ColorSequenceKeypoint.new(0,Color3.fromRGB(220,65,65)),
        ColorSequenceKeypoint.new(1,Color3.fromRGB(160,35,35)),
    })
    ptShowToast("🚀 Push Trophy aktif!","🚀",Color3.fromRGB(80,255,130))
    ptAddLog("Loop dimulai!", Color3.fromRGB(80,255,130))

    PT_STATE.loop = task.spawn(function()
        while PT_STATE.running do
            local h = ptGetHeight()
            PT_STATE.lastHeight = h
            PTHeightValLbl.Text = math.floor(h).." studs"
            pthBarFill.Size = UDim2.new(math.clamp(h/20000,0,1),0,1,0)

            local targetMode
            if ptCheckCondition(PT_CFG.wins, h) then
                targetMode = "WINS"
            elseif ptCheckCondition(PT_CFG.speed, h) then
                targetMode = "SPEED"
            else
                targetMode = "IDLE"
            end

            ptApplyMode(targetMode, h)
            task.wait(0.5)
        end
    end)
end

local function ptStopLoop()
    PT_STATE.running=false
    if PT_STATE.loop then task.cancel(PT_STATE.loop); PT_STATE.loop=nil end
    PT_STATE.currentMode="IDLE"
    PTStatusLbl.Text="● MATI"; PTStatusLbl.TextColor3=Color3.fromRGB(255,80,80)
    PTTogBtn.Text="▶ AKTIFKAN"
    ptTogGrad.Color=ColorSequence.new({
        ColorSequenceKeypoint.new(0,Color3.fromRGB(60,210,115)),
        ColorSequenceKeypoint.new(1,Color3.fromRGB(30,140,65)),
    })
    PTRunLbl.Text="Menunggu diaktifkan..."; PTRunLbl.TextColor3=Color3.fromRGB(100,96,136)
    PTModeIconLbl.Text="〰"
    PTHeightZoneLbl.Text="〰 NORMAL"; PTHeightZoneLbl.TextColor3=Color3.fromRGB(130,125,170)
    ptScSt.Color=Color3.fromRGB(255,215,0)
    ptWinsCS_ref.Transparency=0.5; ptSpeedCS_ref.Transparency=0.5
    ptAddLog("Loop dihentikan.", Color3.fromRGB(255,80,80))
    ptShowToast("⏹ Push Trophy dimatikan","⏹",Color3.fromRGB(255,80,80))
    pushTrophyAktif = false
end

PTTogBtn.MouseButton1Click:Connect(function()
    if PT_STATE.running then
        ptStopLoop()
    else
        pushTrophyAktif = true
        ptStartLoop()
    end
end)

