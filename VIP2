local TABS = {
    souvenir   = {panel=PanelSouvenir,    tab=SvTab, color=Color3.fromRGB(255,200,0)},
    superauto  = {panel=PanelSuperAuto,   tab=SaTab, color=Color3.fromRGB(0,220,255)},
    hatch      = {panel=PanelHatch,       tab=HtTab, color=Color3.fromRGB(160,80,255)},
    pushtrophy = {panel=PanelPushTrophy,  tab=PtTab, color=Color3.fromRGB(255,215,0)},
}

local function switchTab(name)
    activeTab = name
    for k, t in pairs(TABS) do
        t.panel.Visible = (k == name)
        local active = (k == name)
        t.tab.indicator.Visible = active
        if active then
            TweenService:Create(t.tab.frame, TweenInfo.new(0.2), {BackgroundColor3=Color3.fromRGB(18,14,32)}):Play()
            t.tab.stroke.Transparency = 0.25
            t.tab.nameLbl.TextColor3 = t.color
            _fStroke.Color = t.color
            _tbLine.BackgroundColor3 = t.color
        else
            TweenService:Create(t.tab.frame, TweenInfo.new(0.2), {BackgroundColor3=Color3.fromRGB(10,8,20)}):Play()
            t.tab.stroke.Transparency = 0.9
            t.tab.nameLbl.TextColor3 = Color3.fromRGB(90,86,124)
        end
    end
end

