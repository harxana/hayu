        if num then cfg.value = num; valBox.Text = tostring(num)
        else valBox.Text = tostring(cfg.value) end
        if TROPHY_STATE.running then TROPHY_STATE.currentMode = "IDLE" end
    end)

    updateUI()
    return card, cs
end

