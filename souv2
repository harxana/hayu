local function runSouvenirLoop()
    while isSouvenirRunning do
        local ada=false
        for _,sv in ipairs(souvenirs) do if sv.aktif then ada=true break end end
        if not ada then task.wait(0.5) continue end
        for i,sv in ipairs(souvenirs) do
