            if not sv.aktif then continue end
            SvRunLbl.Text="Running: "..sv.name
            local ref=cardRefs[i]; local dur=sv.durasi
            if dur==0 then
                fireSouvenir(sv.slot)
                if ref and ref.timerDisp and ref.timerDisp.Parent then ref.timerDisp.Text="Durasi: 0 dtk | Fire!" end
                task.wait(0.5)
                if ref and ref.timerDisp and ref.timerDisp.Parent then ref.timerDisp.Text="Durasi: 0 dtk | Sisa: -" end
            else
                for t=dur,1,-1 do
                    if not isSouvenirRunning or not sv.aktif then break end
                    fireSouvenir(sv.slot)
                    if ref and ref.timerDisp and ref.timerDisp.Parent then
                        ref.timerDisp.Text="Durasi: "..dur.." dtk | Sisa: "..t.." dtk"
