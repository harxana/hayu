local function setDeleteON()
    DeleteStatusLbl.Text="Status: AKTIF ✅"; DeleteStatusLbl.TextColor3=Color3.fromRGB(80,255,120)
    DeleteToggleBtn.Text="⏹ MATIKAN"
    _delGrad.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(220,70,70)),ColorSequenceKeypoint.new(1,Color3.fromRGB(160,40,40))})
end
local function setDeleteOFF()
    DeleteStatusLbl.Text="Status: MATI"; DeleteStatusLbl.TextColor3=Color3.fromRGB(255,80,80)
    DeleteToggleBtn.Text="▶ NYALAKAN"; DeleteRunLbl.Text="Menunggu..."
    _delGrad.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(60,200,110)),ColorSequenceKeypoint.new(1,Color3.fromRGB(30,140,70))})
end
local function runDeleteLoop()
    while deleteAktif do
        local ada=false
        for _,pet in ipairs(deletePets) do if pet.aktif then ada=true break end end
        if not ada then task.wait(1) continue end
        for n,pet in ipairs(deletePets) do
            if not deleteAktif then break end
            if not pet.aktif then continue end
            DeleteRunLbl.Text="Deleting: "..pet.nama
            fireDeletePet(pet.id)
            deleteCounters[n]+=1
            if deleteCardRefs[n] and deleteCardRefs[n].cntLbl and deleteCardRefs[n].cntLbl.Parent then
                deleteCardRefs[n].cntLbl.Text="Deleted: "..deleteCounters[n]
            end
            task.wait(0.3)
        end
        if deleteDelay>0 then
            for t=deleteDelay,1,-1 do
                if not deleteAktif then break end
                DeleteRunLbl.Text="Jeda: "..t.." dtk"
                task.wait(1)
            end
        else
            task.wait(0.1)
        end
    end
    setDeleteOFF()
end
DeleteToggleBtn.MouseButton1Click:Connect(function()
    deleteAktif=not deleteAktif
    if deleteAktif then setDeleteON(); task.spawn(runDeleteLoop) end
end)

