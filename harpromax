-- UISCALE: semua child Frame ikut skala proporsional
local guiScale = Instance.new("UIScale", Frame)
guiScale.Scale = 1.0

local BASE_W    = 240
local BASE_H    = 315
local currentScale = 1.0
local MIN_SCALE = 0.6
local MAX_SCALE = 2.0
local SCALE_STEP = 0.1

local function applyScale(s)
    currentScale = math.clamp(s, MIN_SCALE, MAX_SCALE)
    currentScale = math.floor(currentScale * 100 + 0.5) / 100
    local nw = math.floor(BASE_W * currentScale)
    local nh = math.floor(BASE_H * currentScale)
    guiScale.Scale = currentScale
    Frame.Size = UDim2.new(0, nw, 0, nh)
    -- Reposisi ke tengah layar setelah resize
    Frame.Position = UDim2.new(0.5, -nw/2, 0.5, -nh/2)
end

