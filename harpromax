local function applyAutoPetMode(mode,h)
    if mode==AUTO_PET_STATE.currentMode then return end
    AUTO_PET_STATE.currentMode=mode
    if mode=="WINS" then
        task.spawn(function() lepasListPet(PET_SPEED_IDS); pasangListPet(PET_WINS_IDS) end)
        local sym=AUTO_PET_CFG.wins.mode=="above" and ">" or "<"
        PetHeightZoneLbl.Text="🏆 WINS"; PetHeightZoneLbl.TextColor3=Color3.fromRGB(255,215,0)
        PetModeIconLbl.Text="🏆"
        PetRunLbl.Text="Pet WINS Y"..sym..AUTO_PET_CFG.wins.value.." ["..math.floor(h).."]"
        PetRunLbl.TextColor3=Color3.fromRGB(255,215,0)
        petHBarFill.BackgroundColor3=Color3.fromRGB(255,215,0); PetWinsCS.Transparency=0.08; PetSpeedCS.Transparency=0.82
    elseif mode=="SPEED" then
        task.spawn(function() lepasListPet(PET_WINS_IDS); pasangListPet(PET_SPEED_IDS) end)
        local sym=AUTO_PET_CFG.speed.mode=="above" and ">" or "<"
        PetHeightZoneLbl.Text="⚡ SPEED"; PetHeightZoneLbl.TextColor3=Color3.fromRGB(80,180,255)
        PetModeIconLbl.Text="⚡"
        PetRunLbl.Text="Pet SPEED Y"..sym..AUTO_PET_CFG.speed.value.." ["..math.floor(h).."]"
        PetRunLbl.TextColor3=Color3.fromRGB(80,200,255)
        petHBarFill.BackgroundColor3=Color3.fromRGB(80,180,255); PetSpeedCS.Transparency=0.08; PetWinsCS.Transparency=0.82
    else
        PetHeightZoneLbl.Text="〰 NORMAL"; PetHeightZoneLbl.TextColor3=Color3.fromRGB(130,125,170)
        PetModeIconLbl.Text="〰"; PetRunLbl.Text="Memantau ketinggian..."; PetRunLbl.TextColor3=Color3.fromRGB(100,96,136)
        PetWinsCS.Transparency=0.5; PetSpeedCS.Transparency=0.5
    end
end

local function startAutoPetLoop()
    AUTO_PET_STATE.running=true; AUTO_PET_STATE.currentMode="IDLE"
    PetStatusLbl.Text="● AKTIF"; PetStatusLbl.TextColor3=Color3.fromRGB(80,255,130)
    PetTogBtn.Text="■ MATIKAN"
    petTogGrad.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(220,65,65)),ColorSequenceKeypoint.new(1,Color3.fromRGB(160,35,35))})
    AUTO_PET_STATE.loop=task.spawn(function()
        while AUTO_PET_STATE.running do
            local h=getTrophyHeight()
            PetHeightValLbl.Text=math.floor(h).." studs"
            petHBarFill.Size=UDim2.new(math.clamp(h/20000,0,1),0,1,0)
            local tgt
            if checkCondition(AUTO_PET_CFG.wins,h) then tgt="WINS"
            elseif checkCondition(AUTO_PET_CFG.speed,h) then tgt="SPEED"
            else tgt="IDLE" end
            applyAutoPetMode(tgt,h); smartDelay(0.5)
        end
    end)
end
local function stopAutoPetLoop()
    AUTO_PET_STATE.running=false
    if AUTO_PET_STATE.loop then task.cancel(AUTO_PET_STATE.loop); AUTO_PET_STATE.loop=nil end
    AUTO_PET_STATE.currentMode="IDLE"
    PetStatusLbl.Text="● MATI"; PetStatusLbl.TextColor3=Color3.fromRGB(255,80,80)
