-- Script LEPAS: DownPet per ID dengan jeda 0.05s
local function downPet(id)
    local args = {"DownPet", id}
    RS:WaitForChild("Msg"):WaitForChild("RemoteEvent"):FireServer(unpack(args))
end

-- Script PASANG: UpPet per ID dengan jeda 0.05s
local function upPet(id)
    local args = {"UpPet", id}
    RS:WaitForChild("Msg"):WaitForChild("RemoteEvent"):FireServer(unpack(args))
end

local function lepasListPet(t)
    for _, id in ipairs(t) do
        pcall(function() downPet(id) end)
        safeWait(0.05)
    end
end

local function pasangListPet(t)
    for _, id in ipairs(t) do
        pcall(function() upPet(id) end)
        safeWait(0.05)
    end
end

