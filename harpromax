local function applyMode(mode,h)
    if mode==TROPHY_STATE.currentMode then return end
    TROPHY_STATE.currentMode=mode
    if mode=="WINS" then
        pcall(fireSouvenirWins); TROPHY_STATE.winsCount+=1; PushCountLbl.Text=tostring(TROPHY_STATE.winsCount)
        local sym=CFG.wins.mode=="above" and ">" or "<"
        HeightZoneLbl.Text="🏆 WINS"; HeightZoneLbl.TextColor3=Color3.fromRGB(255,215,0)
        ModeIconLbl.Text="🏆"
        TrophyRunLbl.Text="WINS Y"..sym..CFG.wins.value.." ["..math.floor(h).."]"
        TrophyRunLbl.TextColor3=Color3.fromRGB(255,215,0)
        hBarFill.BackgroundColor3=Color3.fromRGB(255,215,0); WinsCS.Transparency=0.08; SpeedCS.Transparency=0.82
    elseif mode=="SPEED" then
        pcall(fireSouvenirSpeed)
        local sym=CFG.speed.mode=="above" and ">" or "<"
        HeightZoneLbl.Text="⚡ SPEED"; HeightZoneLbl.TextColor3=Color3.fromRGB(80,180,255)
        ModeIconLbl.Text="⚡"
        TrophyRunLbl.Text="SPEED Y"..sym..CFG.speed.value.." ["..math.floor(h).."]"
        TrophyRunLbl.TextColor3=Color3.fromRGB(80,200,255)
        hBarFill.BackgroundColor3=Color3.fromRGB(80,180,255); SpeedCS.Transparency=0.08; WinsCS.Transparency=0.82
    else
        HeightZoneLbl.Text="〰 NORMAL"; HeightZoneLbl.TextColor3=Color3.fromRGB(130,125,170)
        ModeIconLbl.Text="〰"; TrophyRunLbl.Text="Memantau ketinggian..."; TrophyRunLbl.TextColor3=Color3.fromRGB(100,96,136)
        WinsCS.Transparency=0.5; SpeedCS.Transparency=0.5
    end
end

local function startTrophyLoop()
    TROPHY_STATE.running=true; TROPHY_STATE.currentMode="IDLE"
    TrophyStatusLbl.Text="● AKTIF"; TrophyStatusLbl.TextColor3=Color3.fromRGB(80,255,130)
    TrophyTogBtn.Text="■ MATIKAN"
    togGrad.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(220,65,65)),ColorSequenceKeypoint.new(1,Color3.fromRGB(160,35,35))})
    TROPHY_STATE.loop=task.spawn(function()
        while TROPHY_STATE.running do
            local h=getTrophyHeight()
            HeightValLbl.Text=math.floor(h)
            hBarFill.Size=UDim2.new(math.clamp(h/20000,0,1),0,1,0)
            local tgt
            if checkCondition(CFG.wins,h) then tgt="WINS"
            elseif checkCondition(CFG.speed,h) then tgt="SPEED"
            else tgt="IDLE" end
            applyMode(tgt,h); smartDelay(0.5)
        end
    end)
end
local function stopTrophyLoop()
    TROPHY_STATE.running=false
    if TROPHY_STATE.loop then task.cancel(TROPHY_STATE.loop); TROPHY_STATE.loop=nil end
    TROPHY_STATE.currentMode="IDLE"
    TrophyStatusLbl.Text="● MATI"; TrophyStatusLbl.TextColor3=Color3.fromRGB(255,80,80)
    TrophyTogBtn.Text="▶ AKTIFKAN"
    togGrad.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(60,210,115)),ColorSequenceKeypoint.new(1,Color3.fromRGB(30,140,65))})
    TrophyRunLbl.Text="Menunggu diaktifkan..."; TrophyRunLbl.TextColor3=Color3.fromRGB(100,96,136)
    ModeIconLbl.Text="〰"; HeightZoneLbl.Text="〰 NORMAL"; HeightZoneLbl.TextColor3=Color3.fromRGB(130,125,170)
    WinsCS.Transparency=0.5; SpeedCS.Transparency=0.5
end
TrophyTogBtn.MouseButton1Click:Connect(function()
    if TROPHY_STATE.running then stopTrophyLoop() else startTrophyLoop() end
end)

