-- RESIZE: DRAG TEPI DAN SUDUT
-- ================================================
do
    local HS = 10
    -- dir: 1=atas, 2=bawah, 4=kiri, 8=kanan, combo=sudut
    local handles = {
        {x=HS,y=0,    w=-2*HS,h=HS,   dir=1},   -- atas
        {x=HS,y=-HS,  w=-2*HS,h=HS,   dir=2},   -- bawah
        {x=0, y=HS,   w=HS,   h=-2*HS,dir=4},   -- kiri
        {x=-HS,y=HS,  w=HS,   h=-2*HS,dir=8},   -- kanan
        {x=0, y=0,    w=HS,   h=HS,   dir=5},   -- sudut kiri-atas
        {x=-HS,y=0,   w=HS,   h=HS,   dir=9},   -- sudut kanan-atas
        {x=0, y=-HS,  w=HS,   h=HS,   dir=6},   -- sudut kiri-bawah
        {x=-HS,y=-HS, w=HS,   h=HS,   dir=10},  -- sudut kanan-bawah
    }
    local resizing=false; local rd=0
    local rs=Vector2.zero; local op=Frame.Position; local os=Frame.Size

    for _,h in ipairs(handles) do
        local hf = Instance.new("TextButton",Frame)
        local aX = (h.x < 0) and 1 or 0
        local aY = (h.y < 0) and 1 or 0
        hf.AnchorPoint = Vector2.new(aX,aY)
        hf.Position = UDim2.new(aX, h.x<0 and 0 or h.x, aY, h.y<0 and 0 or h.y)
        hf.Size = UDim2.new(0, math.abs(h.w), 0, math.abs(h.h))
        hf.BackgroundTransparency = 1; hf.Text = ""
        hf.ZIndex = 200; hf.BorderSizePixel = 0; hf.Active = true
        local dir = h.dir
        hf.InputBegan:Connect(function(inp)
            if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then
                resizing=true; rd=dir
                rs=Vector2.new(inp.Position.X,inp.Position.Y)
                op=Frame.Position; os=Frame.Size
            end
        end)
    end

    UIS.InputChanged:Connect(function(inp)
        if not resizing then return end
        if inp.UserInputType~=Enum.UserInputType.MouseMovement and inp.UserInputType~=Enum.UserInputType.Touch then return end
        local vp = workspace.CurrentCamera.ViewportSize
        local dx = inp.Position.X - rs.X
        local dy = inp.Position.Y - rs.Y
        local px,py,pw,ph = op.X.Offset,op.Y.Offset,os.X.Offset,os.Y.Offset
        local nx,ny,nw,nh = px,py,pw,ph
        if rd==1 or rd==5 or rd==9 then
            local c = ph - dy; if c >= MIN_H then nh=c; ny=py+dy end
        end
        if rd==2 or rd==6 or rd==10 then nh = math.max(ph+dy, MIN_H) end
        if rd==4 or rd==5 or rd==6 then
            local c = pw - dx; if c >= MIN_W then nw=c; nx=px+dx end
        end
        if rd==8 or rd==9 or rd==10 then nw = math.max(pw+dx, MIN_W) end
        nw = math.min(nw, MAX_W); nh = math.min(nh, MAX_H)
        nx = math.clamp(nx,0,vp.X-nw); ny = math.clamp(ny,0,vp.Y-nh)
        FRAME_W = nw; FRAME_H = nh
        RsWDisp.Text = tostring(math.floor(nw))
        RsHDisp.Text = tostring(math.floor(nh))
        Frame.Position = UDim2.new(0,nx,0,ny)
        Frame.Size     = UDim2.new(0,nw,0,nh)
    end)
    UIS.InputEnded:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then
            resizing = false
        end
    end)
end

